# HVCKER-CODER-AI Environment Configuration
# Copy this file to .env and fill in your values

# Ollama (Local AI Model - dolphin3-qwen2.5)
OLLAMA_BASE_URL=http://localhost:11434

# E2B (Sandbox + Web Browsing)
E2B_API_KEY=your_e2b_api_key_here

# AI Behavior
AI_TEMPERATURE=0.9
AI_MAX_TOKENS=4096

# Financial/Carding Settings
ENABLE_FINANCIAL_TOOLS=true
ENABLE_CARDING_TOOLS=true
ENABLE_FRAUD_AUTOMATION=true
ENABLE_WEB_SEARCH=true

# Logging
LOG_LEVEL=info
